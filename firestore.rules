rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {uid}
    // Fields: uid, displayName, email, preferredLanguage, gradeLevel, createdAt
    //
    // Collection: sessions
    // Document ID: {sessionId}
    // Fields: uid, concept, explanation, analogy, imageUrl, timestamp
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('preferredLanguage' in data) || data.preferredLanguage in ['English', 'Swahili', 'Sheng']);
    }

    function isValidSession(data) {
      return data.keys().hasAll(['uid', 'concept', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.concept is string &&
             data.concept.size() < 200;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isOwner(uid) && isValidUser(request.resource.data);
    }

    match /sessions/{sessionId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidSession(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
  }
}
